# OpenCut v3.0 环境变量配置

# === LLM Providers（至少配置一个真实 key，占位符会被跳过）===

# MiniMax（Anthropic 兼容，默认 LLM provider；同时用于 TTS）
# 一个 key 同时驱动 LLM 和 TTS，无需单独 TTS key
MINIMAX_API_KEY=your_minimax_key
MINIMAX_API_BASE=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax M3

# DeepSeek（OpenAI 兼容，可选）
DEEPSEEK_API_KEY=your_deepseek_key
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 豆包 / 火山引擎（OpenAI 兼容，多模态视觉，可选 fallback）
# 素材分析优先用 minimax M3 多模态，doubao 作备用（二选一即可）
# 注意：DOUBAO_MODEL 是模型 ID（非显示名），多模态用 doubao-seed-2-0-lite-260428
DOUBAO_API_KEY=your_doubao_key
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-lite-260428

# 通义千问 / DashScope（OpenAI 兼容，可选）
QWEN_API_KEY=your_qwen_key
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# === 图像 API ===
PEXELS_API_KEY=your_pexels_key

# === 路径覆盖（可选）===
# OPENCUT_DATA_DIR=data
# OPENCUT_DOMAINS_DIR=domains
# OPENCUT_REMOTION_DIR=remotion
# OPENCUT_REMOTION_FPS=30
# OPENCUT_CORS_ORIGINS=http://localhost:3000

# === SaaS 层（v0.4.0）===
# JWT 密钥（生产必改，>=32 字节）。默认值仅开发用。
OPENCUT_JWT_SECRET=dev-secret-change-in-production-min32bytes!
# 数据库 URL（默认 SQLite，切 Postgres 改成 postgresql+asyncpg://...）
# OPENCUT_DATABASE_URL=sqlite+aiosqlite:///./data/opencut.db
